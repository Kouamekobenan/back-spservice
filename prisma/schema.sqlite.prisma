// ============================================================
// PRISMA SCHEMA SQLITE — MODE OFFLINE
// ============================================================
// Compatible : SQLite local (Electron / Capacitor / Dev)
// NE PAS MODIFIER schema.prisma (PostgreSQL cloud)
// Dérivé de schema.prisma v2.0.0
//
// Différences vs schema.prisma :
//   - provider = "sqlite"
//   - url = env("DATABASE_URL_SQLITE")
//   - output = client séparé dans .prisma/client-sqlite
//   - Tous les @db.Decimal() SUPPRIMÉS
//   - Tous les Decimal → Float (SQLite stocke en REAL IEEE 754)
//   - Json? reste Json? (Prisma sérialise en TEXT automatiquement)
// ============================================================

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_SQLITE")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-sqlite"
}


// ── ENUMS (Prisma les gère comme String en SQLite) ───────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  AUDITOR
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_CARD
  CREDIT
  MIXED
}

enum SaleStatus {
  COMPLETED
  PARTIALLY_PAID
  VOIDED
  REFUNDED
}

enum StockMovementReason {
  SALE
  PURCHASE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT
  LOSS
  TRANSFER_IN
  TRANSFER_OUT
  INITIAL
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARY
  SUPPLIES
  TRANSPORT
  MAINTENANCE
  TAXES
  MARKETING
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VOID_SALE
  APPLY_DISCOUNT
  PRICE_CHANGE
  STOCK_ADJUSTMENT
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
  ERROR
}

// ── MULTI-BOUTIQUES ──────────────────────────────────────────
model Shop {
  id          String   @id @default(uuid())
  name        String
  address     String?
  phone       String?
  email       String?
  taxId       String?
  logoUrl     String?
  currency    String   @default("XOF")
  isActive    Boolean  @default(true)

  usersAccess    UserShopAccess[]
  products       Product[]
  sales          Sale[]
  expenses       Expense[]
  cashSessions   CashSession[]
  purchaseOrders PurchaseOrder[]
  stockTransfers StockTransfer[]
  auditLogs      AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shops")
}

// ── UTILISATEURS & PERMISSIONS ───────────────────────────────

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  refreshToken String?
  name         String
  phone        String?
  role         Role      @default(CASHIER)
  pin          String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  shopAccesses   UserShopAccess[]
  sales          Sale[]
  cashSessions   CashSession[]
  auditLogs      AuditLog[]
  stockMovements StockMovement[]

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model UserShopAccess {
  id         String  @id @default(uuid())
  userId     String
  shopId     String
  roleInShop Role?

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop       Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([userId, shopId])
  @@map("user_shop_access")
}

// ── CATALOGUE PRODUITS ───────────────────────────────────────

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  colorHex    String?
  iconName    String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Unit {
  id           String    @id @default(uuid())
  name         String    @unique
  abbreviation String
  products     Product[]

  @@map("units")
}

model Product {
  id           String   @id @default(uuid())
  barcode      String?
  sku          String?
  name         String
  description  String?

  // Prix — Float au lieu de Decimal (SQLite stocke en REAL)
  buyingPrice    Float             // ← Decimal @db.Decimal(12,2)
  sellingPrice   Float             // ← Decimal @db.Decimal(12,2)
  wholeSalePrice Float?            // ← Decimal? @db.Decimal(12,2)

  // Stock
  stockQty    Float   @default(0)  // ← Decimal @default(0) @db.Decimal(12,3)
  minStockQty Float   @default(5)  // ← Decimal @default(5) @db.Decimal(12,3)
  maxStockQty Float?               // ← Decimal? @db.Decimal(12,3)

  hasBatchTracking Boolean @default(false)
  metadata         Json?
  isActive         Boolean @default(true)

  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  unitId     String?
  unit       Unit?    @relation(fields: [unitId], references: [id])

  components     ProductComponent[] @relation("ComposedProduct")
  usedIn         ProductComponent[] @relation("ComponentProduct")
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  purchaseItems  PurchaseOrderItem[]
  batches        ProductBatch[]

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barcode, shopId])
  @@unique([sku, shopId])
  @@map("products")
}

model ProductComponent {
  id          String  @id @default(uuid())
  composedId  String
  composed    Product @relation("ComposedProduct", fields: [composedId], references: [id])
  componentId String
  component   Product @relation("ComponentProduct", fields: [componentId], references: [id])
  quantity    Float   // ← Decimal @db.Decimal(12,3)

  @@unique([composedId, componentId])
  @@map("product_components")
}

model ProductBatch {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  batchNumber String
  quantity    Float     // ← Decimal @db.Decimal(12,3)
  expiresAt   DateTime?
  buyingPrice Float     // ← Decimal @db.Decimal(12,2)
  receivedAt  DateTime  @default(now())

  @@map("product_batches")
}

// ── CLIENTS & CRÉDIT ─────────────────────────────────────────

model Customer {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  email       String?
  address     String?
  totalDebt   Float    @default(0)  // ← Decimal @default(0) @db.Decimal(12,2)
  creditLimit Float?                // ← Decimal? @db.Decimal(12,2)
  notes       String?

  sales          Sale[]
  creditPayments CreditPayment[]

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model CreditPayment {
  id         String        @id @default(uuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  amount     Float         // ← Decimal @db.Decimal(12,2)
  method     PaymentMethod
  reference  String?
  notes      String?

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())

  @@map("credit_payments")
}

// ── SESSIONS DE CAISSE ───────────────────────────────────────

model CashSession {
  id     String @id @default(uuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])

  openingBalance  Float         // ← Decimal @db.Decimal(12,2)
  closingBalance  Float?        // ← Decimal? @db.Decimal(12,2)
  expectedBalance Float?        // ← Decimal? @db.Decimal(12,2)
  difference      Float?        // ← Decimal? @db.Decimal(12,2)

  openedAt DateTime  @default(now())
  closedAt DateTime?
  notes    String?

  sales Sale[]

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  @@map("cash_sessions")
}

// ── VENTES & ENCAISSEMENTS ───────────────────────────────────

model Sale {
  id            String     @id @default(uuid())
  receiptNumber String
  status        SaleStatus @default(COMPLETED)

  subtotal       Float      // ← Decimal @db.Decimal(12,2)
  discountAmount Float      @default(0)  // ← Decimal @default(0) @db.Decimal(12,2)
  taxAmount      Float      @default(0)  // ← Decimal @default(0) @db.Decimal(12,2)
  totalAmount    Float      // ← Decimal @db.Decimal(12,2)
  paidAmount     Float      @default(0)  // ← Decimal @default(0) @db.Decimal(12,2)
  changeAmount   Float      @default(0)  // ← Decimal @default(0) @db.Decimal(12,2)

  notes String?

  shopId        String
  shop          Shop         @relation(fields: [shopId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  originalSaleId String?
  originalSale   Sale?   @relation("SaleRefunds", fields: [originalSaleId], references: [id])
  refunds        Sale[]  @relation("SaleRefunds")

  items    SaleItem[]
  payments SalePayment[]

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  productName String
  productSku  String?
  quantity    Float    // ← Decimal @db.Decimal(12,3)
  unitPrice   Float    // ← Decimal @db.Decimal(12,2)
  discount    Float    @default(0)  // ← Decimal @default(0) @db.Decimal(12,2)
  totalPrice  Float    // ← Decimal @db.Decimal(12,2)

  @@map("sale_items")
}

model SalePayment {
  id        String        @id @default(uuid())
  saleId    String
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method    PaymentMethod
  amount    Float         // ← Decimal @db.Decimal(12,2)
  reference String?

  createdAt DateTime @default(now())

  @@map("sale_payments")
}

// ── FOURNISSEURS & APPROVISIONNEMENTS ────────────────────────

model Supplier {
  id       String  @id @default(uuid())
  name     String
  contact  String?
  phone    String?
  email    String?
  address  String?
  notes    String?
  isActive Boolean @default(true)

  purchaseOrders PurchaseOrder[]

  // Sync Offline
  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNumber String
  status      PurchaseOrderStatus @default(DRAFT)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id])

  subtotal    Float    // ← Decimal @db.Decimal(12,2)
  totalAmount Float    // ← Decimal @db.Decimal(12,2)
  amountPaid  Float    @default(0)  // ← Decimal @default(0) @db.Decimal(12,2)

  expectedAt DateTime?
  receivedAt DateTime?
  notes      String?

  items PurchaseOrderItem[]

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  quantityOrdered  Float        // ← Decimal @db.Decimal(12,3)
  quantityReceived Float        @default(0)  // ← Decimal @default(0) @db.Decimal(12,3)
  unitCost         Float        // ← Decimal @db.Decimal(12,2)
  totalCost        Float        // ← Decimal @db.Decimal(12,2)

  @@map("purchase_order_items")
}

// ── MOUVEMENTS DE STOCK ──────────────────────────────────────

model StockMovement {
  id        String              @id @default(uuid())
  productId String
  product   Product             @relation(fields: [productId], references: [id])
  shopId    String

  reason      StockMovementReason
  quantity    Float               // ← Decimal @db.Decimal(12,3)
  stockBefore Float               // ← Decimal @db.Decimal(12,3)
  stockAfter  Float               // ← Decimal @db.Decimal(12,3)
  unitCost    Float?              // ← Decimal? @db.Decimal(12,2)

  saleId          String?
  purchaseOrderId String?
  transferId      String?
  notes           String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())

  @@map("stock_movements")
}

// ── TRANSFERTS INTER-BOUTIQUES ───────────────────────────────

model StockTransfer {
  id             String @id @default(uuid())
  transferNumber String

  fromShopId String
  fromShop   Shop   @relation(fields: [fromShopId], references: [id])
  toShopId   String

  status String   @default("PENDING")
  notes  String?

  items StockTransferItem[]

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stock_transfers")
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String

  quantity Float  // ← Decimal @db.Decimal(12,3)
  unitCost Float  // ← Decimal @db.Decimal(12,2)

  @@map("stock_transfer_items")
}

// ── DÉPENSES OPÉRATIONNELLES ─────────────────────────────────

model Expense {
  id          String          @id @default(uuid())
  title       String
  category    ExpenseCategory
  amount      Float           // ← Decimal @db.Decimal(12,2)
  date        DateTime        @default(now())
  description String?
  receiptUrl  String?
  isRecurring Boolean         @default(false)
  recurringDay Int?

  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id])

  syncStatus SyncStatus @default(SYNCED)
  localId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expenses")
}

// ── AUDIT TRAIL GÉNÉRAL ──────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String
  entityId   String?
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  shopId     String
  shop       Shop        @relation(fields: [shopId], references: [id])

  dataBefore Json?
  dataAfter  Json?
  ipAddress  String?
  userAgent  String?
  notes      String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ── SYNCHRONISATION OFFLINE ──────────────────────────────────

model SyncQueue {
  id         String     @id @default(uuid())
  entityType String
  localId    String
  payload    Json
  operation  String
  retryCount Int        @default(0)
  lastError  String?
  syncStatus SyncStatus @default(PENDING)
  resolvedId String?

  createdAt DateTime  @default(now())
  syncedAt  DateTime?

  @@index([syncStatus, createdAt])
  @@map("sync_queue")
}

// ── CONFIGURATION & PARAMÈTRES ───────────────────────────────

model ShopSetting {
  id     String  @id @default(uuid())
  shopId String?
  key    String
  value  String
  group  String  @default("general")

  @@unique([shopId, key])
  @@map("shop_settings")
}
