generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Shop {
  id             String           @id @default(uuid())
  name           String
  address        String?
  phone          String?
  email          String?
  taxId          String?
  logoUrl        String?
  currency       String           @default("XOF")
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  shopType       ShopType         @default(SUPERMARKET)
  shopTypeLabel  String?
  auditLogs      AuditLog[]
  cashSessions   CashSession[]
  categories     Category[]
  expenses       Expense[]
  products       Product[]
  purchaseOrders PurchaseOrder[]
  sales          Sale[]
  stockTransfers StockTransfer[]
  usersAccess    UserShopAccess[]

  @@map("shops")
}

model User {
  id             String           @id @default(uuid())
  username       String           @unique
  passwordHash   String
  name           String
  role           Role             @default(CASHIER)
  pin            String?
  isActive       Boolean          @default(true)
  syncStatus     SyncStatus       @default(SYNCED)
  localId        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  refreshToken   String?
  phone          String?
  lastLoginAt    DateTime?
  auditLogs      AuditLog[]
  cashSessions   CashSession[]
  sales          Sale[]
  stockMovements StockMovement[]
  shopAccesses   UserShopAccess[]

  @@map("users")
}

model UserShopAccess {
  id         String   @id @default(uuid())
  userId     String
  shopId     String
  roleInShop Role?
  assignedAt DateTime @default(now())
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@map("user_shop_access")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  colorHex    String?
  iconName    String?
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  shopId      String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  shop        Shop?      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("categories")
}

model Unit {
  id           String    @id @default(uuid())
  name         String    @unique
  abbreviation String
  products     Product[]

  @@map("units")
}

model Product {
  id               String              @id @default(uuid())
  barcode          String?
  sku              String?
  name             String
  description      String?
  buyingPrice      Decimal             @db.Decimal(12, 2)
  sellingPrice     Decimal             @db.Decimal(12, 2)
  wholeSalePrice   Decimal?            @db.Decimal(12, 2)
  stockQty         Decimal             @default(0) @db.Decimal(12, 3)
  minStockQty      Decimal             @default(5) @db.Decimal(12, 3)
  maxStockQty      Decimal?            @db.Decimal(12, 3)
  hasBatchTracking Boolean             @default(false)
  metadata         Json?
  isActive         Boolean             @default(true)
  shopId           String
  categoryId       String?
  unitId           String?
  syncStatus       SyncStatus          @default(SYNCED)
  localId          String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  batches          ProductBatch[]
  usedIn           ProductComponent[]  @relation("ComponentProduct")
  components       ProductComponent[]  @relation("ComposedProduct")
  category         Category?           @relation(fields: [categoryId], references: [id])
  shop             Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  unit             Unit?               @relation(fields: [unitId], references: [id])
  purchaseItems    PurchaseOrderItem[]
  saleItems        SaleItem[]
  stockMovements   StockMovement[]

  @@unique([sku, shopId])
  @@index([barcode])
  @@index([shopId])
  @@index([shopId, isActive])
  @@map("products")
}

model ProductComponent {
  id          String  @id @default(uuid())
  composedId  String
  componentId String
  quantity    Decimal @db.Decimal(12, 3)
  component   Product @relation("ComponentProduct", fields: [componentId], references: [id], onDelete: Cascade)
  composed    Product @relation("ComposedProduct", fields: [composedId], references: [id], onDelete: Cascade)

  @@unique([composedId, componentId])
  @@map("product_components")
}

model ProductBatch {
  id          String    @id @default(uuid())
  productId   String
  batchNumber String
  quantity    Decimal   @db.Decimal(12, 3)
  expiresAt   DateTime?
  buyingPrice Decimal   @db.Decimal(12, 2)
  receivedAt  DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_batches")
}

model Customer {
  id             String          @id @default(uuid())
  name           String
  phone          String?
  email          String?
  address        String?
  totalDebt      Decimal         @default(0) @db.Decimal(12, 2)
  creditLimit    Decimal?        @db.Decimal(12, 2)
  notes          String?
  syncStatus     SyncStatus      @default(SYNCED)
  localId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  creditPayments CreditPayment[]
  sales          Sale[]

  @@index([totalDebt])
  @@map("customers")
}

model CreditPayment {
  id         String        @id @default(uuid())
  customerId String
  amount     Decimal       @db.Decimal(12, 2)
  method     PaymentMethod
  reference  String?
  notes      String?
  syncStatus SyncStatus    @default(SYNCED)
  localId    String?
  createdAt  DateTime      @default(now())
  customer   Customer      @relation(fields: [customerId], references: [id])

  @@map("credit_payments")
}

model CashSession {
  id              String     @id @default(uuid())
  shopId          String
  userId          String
  openingBalance  Decimal    @db.Decimal(12, 2)
  closingBalance  Decimal?   @db.Decimal(12, 2)
  expectedBalance Decimal?   @db.Decimal(12, 2)
  difference      Decimal?   @db.Decimal(12, 2)
  openedAt        DateTime   @default(now())
  closedAt        DateTime?
  notes           String?
  syncStatus      SyncStatus @default(SYNCED)
  localId         String?
  shop            Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id])
  sales           Sale[]

  @@map("cash_sessions")
}

model Sale {
  id             String        @id @default(uuid())
  receiptNumber  String
  status         SaleStatus    @default(COMPLETED)
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  changeAmount   Decimal       @default(0) @db.Decimal(12, 2)
  notes          String?
  shopId         String
  userId         String
  customerId     String?
  cashSessionId  String?
  originalSaleId String?
  syncStatus     SyncStatus    @default(SYNCED)
  localId        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          SaleItem[]
  payments       SalePayment[]
  cashSession    CashSession?  @relation(fields: [cashSessionId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  originalSale   Sale?         @relation("SaleRefunds", fields: [originalSaleId], references: [id])
  refunds        Sale[]        @relation("SaleRefunds")
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])

  @@index([shopId, createdAt])
  @@index([userId, createdAt])
  @@index([shopId, status])
  @@index([customerId])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String
  productName String
  productSku  String?
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  product     Product @relation(fields: [productId], references: [id])
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_items")
}

model SalePayment {
  id        String        @id @default(uuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  createdAt DateTime      @default(now())
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  contact        String?
  phone          String?
  email          String?
  address        String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  localId        String?
  syncStatus     SyncStatus      @default(SYNCED)
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNumber String
  status      PurchaseOrderStatus @default(DRAFT)
  supplierId  String
  shopId      String
  subtotal    Decimal             @db.Decimal(12, 2)
  totalAmount Decimal             @db.Decimal(12, 2)
  amountPaid  Decimal             @default(0) @db.Decimal(12, 2)
  expectedAt  DateTime?
  receivedAt  DateTime?
  notes       String?
  syncStatus  SyncStatus          @default(SYNCED)
  localId     String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       PurchaseOrderItem[]
  shop        Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier    Supplier            @relation(fields: [supplierId], references: [id])

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  productId        String
  quantityOrdered  Decimal       @db.Decimal(12, 3)
  quantityReceived Decimal       @default(0) @db.Decimal(12, 3)
  unitCost         Decimal       @db.Decimal(12, 2)
  totalCost        Decimal       @db.Decimal(12, 2)
  product          Product       @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model StockMovement {
  id              String              @id @default(uuid())
  productId       String
  shopId          String
  reason          StockMovementReason
  quantity        Decimal             @db.Decimal(12, 3)
  stockBefore     Decimal             @db.Decimal(12, 3)
  stockAfter      Decimal             @db.Decimal(12, 3)
  unitCost        Decimal?            @db.Decimal(12, 2)
  saleId          String?
  purchaseOrderId String?
  transferId      String?
  notes           String?
  userId          String
  syncStatus      SyncStatus          @default(SYNCED)
  localId         String?
  createdAt       DateTime            @default(now())
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([shopId, createdAt])
  @@map("stock_movements")
}

model StockTransfer {
  id             String              @id @default(uuid())
  transferNumber String
  fromShopId     String
  toShopId       String
  status         String              @default("PENDING")
  notes          String?
  syncStatus     SyncStatus          @default(SYNCED)
  localId        String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          StockTransferItem[]
  fromShop       Shop                @relation(fields: [fromShopId], references: [id], onDelete: Cascade)

  @@map("stock_transfers")
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  productId  String
  quantity   Decimal       @db.Decimal(12, 3)
  unitCost   Decimal       @db.Decimal(12, 2)
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("stock_transfer_items")
}

model Expense {
  id           String          @id @default(uuid())
  title        String
  category     ExpenseCategory
  amount       Decimal         @db.Decimal(12, 2)
  date         DateTime        @default(now())
  description  String?
  receiptUrl   String?
  isRecurring  Boolean         @default(false)
  recurringDay Int?
  shopId       String
  syncStatus   SyncStatus      @default(SYNCED)
  localId      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  shop         Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, date])
  @@map("expenses")
}

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String
  entityId   String?
  userId     String?
  shopId     String
  dataBefore Json?
  dataAfter  Json?
  ipAddress  String?
  userAgent  String?
  notes      String?
  createdAt  DateTime    @default(now())
  shop       Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model SyncQueue {
  id         String     @id @default(uuid())
  entityType String
  localId    String
  payload    Json
  operation  String
  retryCount Int        @default(0)
  lastError  String?
  syncStatus SyncStatus @default(PENDING)
  resolvedId String?
  createdAt  DateTime   @default(now())
  syncedAt   DateTime?

  @@index([syncStatus, createdAt])
  @@map("sync_queue")
}

model ChangeLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  operation  String
  shopId     String?
  payload    Json
  changedAt  DateTime @default(now())

  @@index([changedAt])
  @@index([shopId, changedAt])
  @@index([entityType, changedAt])
  @@map("change_log")
}

model ShopSetting {
  id     String  @id @default(uuid())
  shopId String?
  key    String
  value  String
  group  String  @default("general")

  @@unique([shopId, key])
  @@map("shop_settings")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  AUDITOR
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_CARD
  CREDIT
  MIXED
}

enum SaleStatus {
  COMPLETED
  PARTIALLY_PAID
  VOIDED
  REFUNDED
}

enum StockMovementReason {
  SALE
  PURCHASE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT
  LOSS
  TRANSFER_IN
  TRANSFER_OUT
  INITIAL
}

enum ShopType {
  SUPERMARKET
  HARDWARE
  PHARMACY
  RESTAURANT
  GAS_STATION
  CLOTHING
  ELECTRONICS
  BAKERY
  WHOLESALE
  OTHER
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARY
  SUPPLIES
  TRANSPORT
  MAINTENANCE
  TAXES
  MARKETING
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VOID_SALE
  APPLY_DISCOUNT
  PRICE_CHANGE
  STOCK_ADJUSTMENT
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
  ERROR
}
